{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/main.ts", "src/analytics.ts", "src/git.ts", "src/scanner.ts", "src/types.ts", "src/constants.ts"],
  "exclude": ["src/renderer.ts"]
}