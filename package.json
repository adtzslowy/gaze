{
  "name": "gaze",
  "version": "1.0.0",
  "description": "Dashboard analisis code terinspirasi dari Triforce.nvim",
  "license": "MIT",
  "author": {
    "name": "adtzslowy",
    "email": "aditzkun0987@gmail.com"
  },
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && tsc -p tsconfig.web.json && mkdir -p dist/assets/fa/css dist/assets/fa/webfonts && cp src/index.html dist/ && cp src/preload.js dist/ && cp assets/app.css dist/assets/ && cp node_modules/@fortawesome/fontawesome-free/css/all.min.css dist/assets/fa/css/ && cp node_modules/@fortawesome/fontawesome-free/webfonts/* dist/assets/fa/webfonts/",
    "dev": "tsx src/main.ts --dev 2>/dev/null",
    "start": "npm run build && electron . --dev",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:all": "npm run build && electron-builder --mac --win --linux"
  },
  "build": {
    "appId": "com.adtzslowy.gaze",
    "productName": "Gaze",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "!dist/**/*.map"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "icon": "icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "icon.png",
      "category": "Development",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "electron": "^41.1.1",
    "electron-builder": "^25.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.5.1"
  }
}
